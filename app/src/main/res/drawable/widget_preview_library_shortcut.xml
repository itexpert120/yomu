<?xml version="1.0" encoding="utf-8"?>
<!-- Static preview shown in the widget picker for the library shortcut tile. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#171815" />
        </shape>
    </item>
    <item
        android:width="40dp"
        android:height="40dp"
        android:gravity="center">
        <bitmap
            android:src="@drawable/ic_yomu_mark"
            android:gravity="center" />
    </item>
</layer-list>
