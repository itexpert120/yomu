<?xml version="1.0" encoding="utf-8"?>
<!-- Static preview shown in the widget picker for the library widget: a 2x2 cover grid. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#171815" />
        </shape>
    </item>
    <!-- Top-left cover. -->
    <item android:left="12dp" android:top="12dp" android:width="78dp" android:height="62dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#0C0D0B" />
        </shape>
    </item>
    <!-- Top-right cover. -->
    <item android:left="100dp" android:top="12dp" android:width="78dp" android:height="62dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#2C2F29" />
        </shape>
    </item>
    <!-- Bottom-left cover. -->
    <item android:left="12dp" android:top="84dp" android:width="78dp" android:height="62dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#2C2F29" />
        </shape>
    </item>
    <!-- Bottom-right cover. -->
    <item android:left="100dp" android:top="84dp" android:width="78dp" android:height="62dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#0C0D0B" />
        </shape>
    </item>
</layer-list>
