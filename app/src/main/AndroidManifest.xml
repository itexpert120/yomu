<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Word definition lookups via the Free Dictionary API. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".YomuApplication"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="33"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Yomu">
        <activity
            android:name=".app.devgallery.DevGalleryActivity"
            android:exported="false"
            android:theme="@style/Theme.Yomu" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Yomu.Starting"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Open an EPUB declared with the correct mime type (file managers, document apps). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:mimeType="application/epub+zip" />
            </intent-filter>

            <!-- Real-world fallback: many senders use a generic/octet-stream mime, so match on the
                 .epub path. pathPattern needs scheme+host, so we enumerate the common schemes/hosts
                 and the leading-".*" workaround for paths with arbitrary prefixes. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:host="*" />
                <data android:mimeType="application/octet-stream" />
                <data android:mimeType="application/zip" />
                <data android:mimeType="*/*" />
                <data android:pathPattern=".*\\.epub" />
                <data android:pathPattern=".*\\..*\\.epub" />
                <data android:pathPattern=".*\\..*\\..*\\.epub" />
                <data android:pathPattern=".*\\..*\\..*\\..*\\.epub" />
            </intent-filter>

            <!-- Share a single EPUB into Yomu (WhatsApp/Gmail/etc.). -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="application/epub+zip" />
            </intent-filter>
        </activity>

        <!-- Resizable library widget: recent books as a fast-launch cover grid (Jetpack Glance).
             Temporarily disabled (android:enabled="false") — re-enable to restore the widget. -->
        <receiver
            android:name=".widget.LibraryWidgetReceiver"
            android:enabled="false"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/library_widget_info" />
        </receiver>

        <!-- Resizable reading-activity widget: streak, time, and a daily heatmap (Jetpack Glance).
             Temporarily disabled (android:enabled="false") — re-enable to restore the widget. -->
        <receiver
            android:name=".widget.ActivityWidgetReceiver"
            android:enabled="false"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/activity_widget_info" />
        </receiver>
    </application>

</manifest>
