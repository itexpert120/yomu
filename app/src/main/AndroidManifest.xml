<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Word definition lookups via the Free Dictionary API. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".YomuApplication"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="33"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Yomu">
        <activity
            android:name=".app.devgallery.DevGalleryActivity"
            android:exported="false"
            android:theme="@style/Theme.Yomu" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Yomu.Starting"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- "Continue reading" home-screen widget (Jetpack Glance). -->
        <receiver
            android:name=".widget.ContinueReadingWidgetReceiver"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/continue_reading_widget_info" />
        </receiver>

        <!-- Small library/open-app shortcut tile (Jetpack Glance). -->
        <receiver
            android:name=".widget.LibraryShortcutWidgetReceiver"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/library_shortcut_widget_info" />
        </receiver>
    </application>

</manifest>
